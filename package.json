    "@types/minimatch": "^5.1.2",
    "@types/node": "^20.12.12",
    "@types/yargs": "^17.0.32",
    "@typescript/server-harness": "^0.3.5",
    "dedent": "^1.5.3",
    "less": "^4.2.0",
    "npm-run-all2": "^6.2.0",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "postcss-import": "^16.1.0",
    "postcss-simple-vars": "^7.0.1",
    "sass": "^1.77.1",
    "typescript": "^5.4.5",
    "vitest": "^2.1.4"
